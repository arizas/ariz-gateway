{
  "name": "near-rpc-proxy-worker",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "tail": "wrangler tail",
    "secret:set-rpc-url": "wrangler secret put NEAR_RPC_URL --env production",
    "secret:enable-auth": "wrangler secret put ENABLE_AUTH --env production",
    "test": "node --test '*.test.js'"
  },
  "devDependencies": {
    "near-api-js": "^3.0.4",
    "wrangler": "^3.0.0"
  }
}
